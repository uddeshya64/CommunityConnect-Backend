generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Uses the connection pool
  directUrl = env("DIRECT_URL")   // Uses the direct connection for migrations
}

// --- 1. ENUMS ---

enum GlobalRole {
  USER
  ADMIN
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  ENDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum VolunteerStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// --- 2. MODELS ---

model User {
  id          String     @id @default(uuid()) @db.Uuid
  fullName    String
  email       String     @unique
  phone       String?    @unique
  password    String     // Hashed
  affiliation String?
  profileUrl  String?
  skills      Json?      @default("[]") // PostgreSQL JSONB
  
  // Platform Level Role
  globalRole  GlobalRole @default(USER)

  // Relations
  eventsOrganized Event[]        @relation("OrganizerEvents")
  teamsLed        Team[]         @relation("TeamLeader")
  registrations   Registration[]
  volunteering    Volunteer[]    @relation("VolunteerUser")
  assignedIssues  EventIssue[]   @relation("AssignedVolunteer")
  raisedIssues    EventIssue[]   @relation("IssueRaiser")
  mentoring       Mentor[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  organizerId String      @db.Uuid
  organizer   User        @relation("OrganizerEvents", fields: [organizerId], references: [id])
  
  title       String
  description String?     @db.Text
  eventType   String      // "Hackathon", "Meetup"
  mode        EventMode
  bannerUrl   String?
  slug        String?     @unique
  
  startDate   DateTime
  endDate     DateTime
  
  rewards     Json?       // e.g. [{"rank": 1, "prize": "Laptop"}]
  settings    Json?       @default("{}") // e.g. {"max_team_size": 4}
  
  status      EventStatus @default(DRAFT)
  
  // Relations
  teams         Team[]
  registrations Registration[]
  transactions  Transaction[]
  volunteers    Volunteer[]
  mentors       Mentor[]
  issues        EventIssue[]

  createdAt   DateTime    @default(now())
}

model Team {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String
  inviteCode           String   @unique
  
  eventId              String   @db.Uuid
  event                Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  leaderId             String   @db.Uuid
  leader               User     @relation("TeamLeader", fields: [leaderId], references: [id])
  
  projectSubmissionUrl String?
  
  members              Registration[]
  
  createdAt            DateTime @default(now())
}

model Registration {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid
  user          User          @relation(fields: [userId], references: [id])
  
  eventId       String        @db.Uuid
  event         Event         @relation(fields: [eventId], references: [id])
  
  teamId        String?       @db.Uuid
  team          Team?         @relation(fields: [teamId], references: [id])
  
  ticketQrCode  String?       @unique
  checkInStatus TicketStatus  @default(ACTIVE)
  paymentStatus PaymentStatus @default(PENDING)
  
  transactions  Transaction[]

  createdAt     DateTime      @default(now())
  
  // Constraint: One ticket per user per event
  @@unique([userId, eventId])
}

model Transaction {
  id             String        @id @default(uuid()) @db.Uuid
  registrationId String        @db.Uuid
  registration   Registration  @relation(fields: [registrationId], references: [id])
  
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("INR")
  status         PaymentStatus
  gatewayTxnId   String?
  
  eventId        String?       @db.Uuid
  event          Event?        @relation(fields: [eventId], references: [id]) // Optional link for analytics

  createdAt      DateTime      @default(now())
}

model Volunteer {
  id             String          @id @default(uuid()) @db.Uuid
  userId         String          @db.Uuid
  user           User            @relation("VolunteerUser", fields: [userId], references: [id], onDelete: Cascade)
  
  eventId        String          @db.Uuid
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  responsibility String
  status         VolunteerStatus @default(PENDING)
  about          String?
}

model EventIssue {
  id                  String      @id @default(uuid()) @db.Uuid
  eventId             String      @db.Uuid
  event               Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  raisedByUserId      String      @db.Uuid
  raisedByUser        User        @relation("IssueRaiser", fields: [raisedByUserId], references: [id])
  
  assignedVolunteerId String?     @db.Uuid
  assignedVolunteer   User?       @relation("AssignedVolunteer", fields: [assignedVolunteerId], references: [id])
  
  title               String
  description         String?
  status              IssueStatus @default(OPEN)
  escalationReason    String?
  
  createdAt           DateTime    @default(now())
  resolvedAt          DateTime?
}

model Mentor {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  eventId       String   @db.Uuid
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  skill         String
  assignedTeams Json?    @default("[]") // Array of Team IDs
}