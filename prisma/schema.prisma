generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Uses the connection pool
  directUrl = env("DIRECT_URL") // Uses the direct connection for migrations
}

// --- Enums ---

enum EventType {
  hackathon
  workshop
  meetup
}

enum EventMode {
  online
  offline
  hybrid
}

enum RegistrationStatus {
  pending
  confirmed
  cancelled
}

enum PaymentStatus {
  pending
  success
  failed
}

enum TeamStatus {
  draft
  active
  locked
  disqualified
}

// --- Models ---

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  phone         String? // 'number' is usually best stored as String to preserve formatting/leading zeros
  password_hash String
  skills        String[] // Array type
  linkedin      String?
  github        String?
  profession    String?
  bio           String?
  avatar_url    String?
  location      String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relationships
  events_created     Event[]            @relation("CreatedEvents")
  event_roles        EventUserRole[]
  registrations      Registration[]
  teams_led          Team[]             @relation("TeamLeader")
  team_memberships   TeamMember[]
  submissions        Submission[]
  mentor_assignments MentorAssignment[]

  @@map("users")
}

model Event {
  id                Int       @id @default(autoincrement())
  title             String    @db.VarChar(150)
  description       String
  type              EventType
  mode              EventMode
  banner_url        String?
  logo_url          String?
  start_date        DateTime
  end_date          DateTime
  registration_type String
  registration_fee  Decimal // 'number' for money is best as Decimal
  max_team_size     Int
  min_team_size     Int
  location          String?
  rewards           Json? @default("{}") // 'jsonb'
  created_by        Int
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

// Relationships
  creator            User                  @relation("CreatedEvents", fields: [created_by], references: [id])
  user_roles         EventUserRole[]
  role_definitions   EventRoleDefinition[] 
  staff_invites      EventStaffInvite[]    
  registrations      Registration[]
  teams              Team[]
  submissions        Submission[]
  mentor_assignments MentorAssignment[]
  announcements      EventAnnouncement[]

  @@map("events")
}

model EventUserRole {
  id                   Int       @id @default(autoincrement())
  event_id             Int
  user_id              Int
  role_id              Int       // <--- CHANGED: Points to EventRoleDefinition.id
  permissions_override Json?     // <--- Keeps the ability to give specific users extra powers
  assigned_at          DateTime  @default(now())

  // Relationships
  event Event               @relation(fields: [event_id], references: [id])
  user  User                @relation(fields: [user_id], references: [id])
  role  EventRoleDefinition @relation(fields: [role_id], references: [id]) // <--- ADDED

  @@unique([event_id, user_id]) 
  @@map("event_user_roles")
}

model Registration {
  id         Int                @id @default(autoincrement())
  event_id   Int
  user_id    Int
  team_id    Int? // Optional, only for hackathons
  status     RegistrationStatus
  created_at DateTime           @default(now())

  // Relationships
  event    Event     @relation(fields: [event_id], references: [id])
  user     User      @relation(fields: [user_id], references: [id])
  team     Team?     @relation(fields: [team_id], references: [id])
  payments Payment[]

  @@map("registrations")
}

model Payment {
  id              Int           @id @default(autoincrement())
  registration_id Int
  amount          Decimal
  currency        String
  provider        String
  status          PaymentStatus
  transaction_ref String?       @db.VarChar(100)
  created_at      DateTime      @default(now())

  // Relationships
  registration Registration @relation(fields: [registration_id], references: [id])

  @@map("payments")
}

// THIS MODEL: To track pending email invites
model TeamInvite {
  id         Int      @id @default(autoincrement())
  team_id    Int
  email      String   // The email of the person being invited
  token      String   @unique // A secure random string for the Magic Link
  status     String   @default("pending") // pending, accepted, expired
  created_at DateTime @default(now())
  expires_at DateTime

  team       Team     @relation(fields: [team_id], references: [id])

  @@unique([team_id, email]) // Prevent spamming the same email for the same team
  @@map("team_invites")
}

model Team {
  id         Int        @id @default(autoincrement())
  name       String
  event_id   Int
  leader_id  Int
  status     TeamStatus
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  // Relationships
  event              Event              @relation(fields: [event_id], references: [id])
  leader             User               @relation("TeamLeader", fields: [leader_id], references: [id])
  registrations      Registration[]
  members            TeamMember[]
  submissions        Submission[]
  mentor_assignments MentorAssignment[]
  invites TeamInvite[]

  @@map("teams")
}

model TeamMember {
  team_id Int
  user_id Int

  // Relationships
  team Team @relation(fields: [team_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@id([team_id, user_id]) // Composite Primary Key
  @@map("team_members")
}

model Submission {
  id           Int      @id @default(autoincrement())
  event_id     Int
  team_id      Int
  user_id      Int
  title        String   @db.VarChar(150)
  repo_url     String?
  submitted_at DateTime @default(now())

  // Relationships
  event Event @relation(fields: [event_id], references: [id])
  team  Team  @relation(fields: [team_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id])

  @@map("submissions")
}

model MentorAssignment {
  event_id  Int
  mentor_id Int
  team_id   Int

  // Relationships
  event  Event @relation(fields: [event_id], references: [id])
  mentor User  @relation(fields: [mentor_id], references: [id])
  team   Team  @relation(fields: [team_id], references: [id])

  @@id([event_id, mentor_id, team_id]) // Composite PK
  @@map("mentor_assignments")
}

model EventAnnouncement {
  id         Int      @id @default(autoincrement())
  event_id   Int
  message    String
  created_at DateTime @default(now())

  // Relationships
  event Event @relation(fields: [event_id], references: [id])

  @@map("event_announcements")
}

model EventRoleDefinition {
  id          Int      @id @default(autoincrement())
  event_id    Int
  name        String   @db.VarChar(50) 
  permissions Json     
  is_system   Boolean  @default(false) 

  // Relationships
  event         Event              @relation(fields: [event_id], references: [id])
  users         EventUserRole[] 
  staff_invites EventStaffInvite[] 

  @@unique([event_id, name]) 
  @@map("event_role_definitions")
}

model EventStaffInvite {
  id         Int      @id @default(autoincrement())
  event_id   Int
  email      String   @db.VarChar(255)
  role_id    Int      // The role they are being invited to fill
  token      String   @unique
  status     String   @default("pending") // pending, accepted, expired
  created_at DateTime @default(now())
  expires_at DateTime

  // Relationships
  event      Event               @relation(fields: [event_id], references: [id])
  role       EventRoleDefinition @relation(fields: [role_id], references: [id])

  @@unique([event_id, email]) // Prevent spamming the same person for the same event
  @@map("event_staff_invites")
}