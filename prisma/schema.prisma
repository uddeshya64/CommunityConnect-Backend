generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* =======================
   MODELS
======================= */

model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(150)
  phone        String?   @db.VarChar(20)
  passwordHash String    @db.Text

  skills       String[]

  linkedin     String?   @db.VarChar(255)
  github       String?   @db.VarChar(255)
  profession   String?   @db.VarChar(100)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdEvents     Event[]            @relation("CreatedEvents")
  eventUserRoles    EventUserRole[]
  registrations     Registration[]
  teamsLed          Team[]             @relation("TeamLeader")
  teamMemberships   TeamMember[]
  submissions       Submission[]
  mentorAssignments MentorAssignment[]
}

model Event {
  id               Int       @id @default(autoincrement())
  title            String    @db.VarChar(150)
  description      String    @db.Text

  type             EventType
  mode             EventMode

  bannerUrl        String?   @db.VarChar(255)
  logoUrl          String?   @db.VarChar(255)

  startDate        DateTime
  endDate          DateTime

  registrationType RegistrationType
  registrationFee  Decimal   @db.Decimal(10, 2)

  maxTeamSize      Int?
  minTeamSize      Int?

  rewards          Json?

  createdById      Int
  createdBy        User      @relation("CreatedEvents", fields: [createdById], references: [id])

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  roles             EventUserRole[]
  registrations     Registration[]
  teams             Team[]
  announcements     EventAnnouncement[]
  submissions       Submission[]
  mentorAssignments MentorAssignment[]
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  eventUserRoles EventUserRole[]
}

model EventUserRole {
  id         Int      @id @default(autoincrement())
  assignedAt DateTime @default(now())

  eventId Int
  userId  Int
  roleId  Int

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  role  Role  @relation(fields: [roleId], references: [id])

  @@unique([eventId, userId, roleId])
}

model Registration {
  id        Int      @id @default(autoincrement())
  status    RegistrationStatus
  createdAt DateTime @default(now())

  eventId Int
  userId  Int
  teamId  Int?

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  team  Team? @relation(fields: [teamId], references: [id])

  payment Payment?

  @@unique([eventId, userId])
}

model Payment {
  id             Int      @id @default(autoincrement())

  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @db.Char(3)

  provider       PaymentProvider
  status         PaymentStatus

  transactionRef String   @unique @db.VarChar(100)
  createdAt      DateTime @default(now())

  registrationId Int   @unique
  registration   Registration @relation(fields: [registrationId], references: [id])
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  status    TeamStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId  Int
  leaderId Int

  event   Event @relation(fields: [eventId], references: [id])
  leader  User  @relation("TeamLeader", fields: [leaderId], references: [id])

  members           TeamMember[]
  registrations     Registration[]
  submissions       Submission[]
  mentorAssignments MentorAssignment[]
}

model TeamMember {
  teamId Int
  userId Int

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([teamId, userId])
}

model Submission {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(150)
  repoUrl     String?  @db.VarChar(255)
  submittedAt DateTime @default(now())

  eventId Int
  teamId  Int
  userId  Int

  event Event @relation(fields: [eventId], references: [id])
  team  Team  @relation(fields: [teamId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model MentorAssignment {
  eventId  Int
  mentorId Int
  teamId   Int

  event  Event @relation(fields: [eventId], references: [id])
  mentor User  @relation(fields: [mentorId], references: [id])
  team   Team  @relation(fields: [teamId], references: [id])

  @@id([eventId, mentorId, teamId])
}

model EventAnnouncement {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  createdAt DateTime @default(now())

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])
}

/* =======================
   ENUMS
======================= */

enum EventType {
  hackathon
  workshop
  meetup
}

enum EventMode {
  online
  offline
  hybrid
}

enum RegistrationType {
  individual
  team
  invite_only
}

enum RegistrationStatus {
  pending
  confirmed
  cancelled
}

enum PaymentStatus {
  pending
  success
  failed
}

enum PaymentProvider {
  stripe
  razorpay
  paypal
}

enum TeamStatus {
  draft
  active
  locked
  disqualified
}
