generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Uses the connection pool
  directUrl = env("DIRECT_URL") // Uses the direct connection for migrations
}

// --- Enums ---

enum EventType {
  hackathon
  workshop
  meetup
}

enum EventMode {
  online
  offline
  hybrid
}

enum RegistrationStatus {
  pending
  confirmed
  cancelled
}

enum PaymentStatus {
  pending
  success
  failed
}

enum TeamStatus {
  draft
  active
  locked
  disqualified
}

// --- Models ---

model User {
  id          String     @id @default(uuid()) @db.Uuid
  fullName    String
  email       String     @unique
  phone       String?    @unique
  password    String     // Hashed
  affiliation String?
  profileUrl  String?
  skills      Json?      @default("[]") // PostgreSQL JSONB
  
  // Platform Level Role
  globalRole  GlobalRole @default(USER)

  // Relations
  eventsOrganized Event[]        @relation("OrganizerEvents")
  teamsLed        Team[]         @relation("TeamLeader")
  registrations   Registration[]
  volunteering    Volunteer[]    @relation("VolunteerUser")
  assignedIssues  EventIssue[]   @relation("AssignedVolunteer")
  raisedIssues    EventIssue[]   @relation("IssueRaiser")
  mentoring       Mentor[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Event {
  id                Int       @id @default(autoincrement())
  title             String    @db.VarChar(150)
  description       String
  type              EventType
  mode              EventMode
  banner_url        String?
  logo_url          String?
  start_date        DateTime
  end_date          DateTime
  registration_type String
  registration_fee  Decimal // 'number' for money is best as Decimal
  max_team_size     Int
  min_team_size     Int
  rewards           Json // 'jsonb'
  created_by        Int
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  // Relationships
  creator            User                @relation("CreatedEvents", fields: [created_by], references: [id])
  user_roles         EventUserRole[]
  registrations      Registration[]
  teams              Team[]
  submissions        Submission[]
  mentor_assignments MentorAssignment[]
  announcements      EventAnnouncement[]

  @@map("events")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(50)

  // Relationships
  event_user_roles EventUserRole[]

  @@map("roles")
}

model EventUserRole {
  id          Int      @id @default(autoincrement())
  event_id    Int
  user_id     Int
  role_id     Int
  assigned_at DateTime @default(now())

  // Relationships
  event Event @relation(fields: [event_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id])
  role  Role  @relation(fields: [role_id], references: [id])

  @@map("event_user_roles")
}

model Registration {
  id         Int                @id @default(autoincrement())
  event_id   Int
  user_id    Int
  team_id    Int? // Optional, only for hackathons
  status     RegistrationStatus
  created_at DateTime           @default(now())

  // Relationships
  event    Event     @relation(fields: [event_id], references: [id])
  user     User      @relation(fields: [user_id], references: [id])
  team     Team?     @relation(fields: [team_id], references: [id])
  payments Payment[]

  @@map("registrations")
}

model Payment {
  id              Int           @id @default(autoincrement())
  registration_id Int
  amount          Decimal
  currency        String
  provider        String
  status          PaymentStatus
  transaction_ref String?       @db.VarChar(100)
  created_at      DateTime      @default(now())

  // Relationships
  registration Registration @relation(fields: [registration_id], references: [id])

  @@map("payments")
}

model Team {
  id         Int        @id @default(autoincrement())
  name       String
  event_id   Int
  leader_id  Int
  status     TeamStatus
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  // Relationships
  event              Event              @relation(fields: [event_id], references: [id])
  leader             User               @relation("TeamLeader", fields: [leader_id], references: [id])
  registrations      Registration[]
  members            TeamMember[]
  submissions        Submission[]
  mentor_assignments MentorAssignment[]

  @@map("teams")
}

model TeamMember {
  team_id Int
  user_id Int

  // Relationships
  team Team @relation(fields: [team_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@id([team_id, user_id]) // Composite Primary Key
  @@map("team_members")
}

model Submission {
  id           Int      @id @default(autoincrement())
  event_id     Int
  team_id      Int
  user_id      Int
  title        String   @db.VarChar(150)
  repo_url     String?
  submitted_at DateTime @default(now())

  // Relationships
  event Event @relation(fields: [event_id], references: [id])
  team  Team  @relation(fields: [team_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id])

  @@map("submissions")
}

model MentorAssignment {
  event_id  Int
  mentor_id Int
  team_id   Int

  // Relationships
  event  Event @relation(fields: [event_id], references: [id])
  mentor User  @relation(fields: [mentor_id], references: [id])
  team   Team  @relation(fields: [team_id], references: [id])

  @@id([event_id, mentor_id, team_id]) // Composite PK
  @@map("mentor_assignments")
}

model Mentor {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  eventId       String   @db.Uuid
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  skill         String
  assignedTeams Json?    @default("[]") // Array of Team IDs
}